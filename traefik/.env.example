# Copy this file to .env and adjust values for your environment.
# Docker Compose will substitute these values in docker-compose.yml.

TRAEFIK_DASHBOARD_HOST=dev.localhost

# --- TLS: Let's Encrypt (production) ---
# Leave both empty for local dev — Traefik will use the mkcert certs in ./certs via tls.yaml.
# For production: set ACME_EMAIL to a real address and CERT_RESOLVER=letsencrypt.
# Port 80 must be publicly reachable for the TLS challenge to succeed.
ACME_EMAIL=
CERT_RESOLVER=
