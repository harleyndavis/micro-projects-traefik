# Must match traefik/.env values.
# HOME_URL and ASSETS_URL are derived from DOMAIN automatically — no need to set them here.
DOMAIN=dev.localhost
CERT_RESOLVER=

# App-specific vars below.

# Django settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=shortener
DB_USER=postgres
DB_PASSWORD=postgres
